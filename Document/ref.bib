@misc{zhuTAMERTreeawareTransformer2024,
  title = {{{TAMER}}: {{Tree-aware}} Transformer for Handwritten Mathematical Expression Recognition},
  shorttitle = {{{TAMER}}},
  author = {Zhu, Jianhua and Zhao, Wenqi and Li, Yu and Hu, Xingjian and Gao, Liangcai},
  year = {2024},
  month = aug,
  journal = {arXiv.org},
  urldate = {2025-06-19},
  abstract = {Handwritten Mathematical Expression Recognition (HMER) has extensive applications in automated grading and office automation. However, existing sequence-based decoding methods, which directly predict \${\textbackslash}LaTeX\$ sequences, struggle to understand and model the inherent tree structure of \${\textbackslash}LaTeX\$ and often fail to ensure syntactic correctness in the decoded results. To address these challenges, we propose a novel model named TAMER (Tree-Aware Transformer) for handwritten mathematical expression recognition. TAMER introduces an innovative Tree-aware Module while maintaining the flexibility and efficient training of Transformer. TAMER combines the advantages of both sequence decoding and tree decoding models by jointly optimizing sequence prediction and tree structure prediction tasks, which enhances the model's understanding and generalization of complex mathematical expression structures. During inference, TAMER employs a Tree Structure Prediction Scoring Mechanism to improve the structural validity of the generated \${\textbackslash}LaTeX\$ sequences. Experimental results on CROHME datasets demonstrate that TAMER outperforms traditional sequence decoding and tree decoding models, especially in handling complex mathematical structures, achieving state-of-the-art (SOTA) performance.},
  howpublished = {https://arxiv.org/abs/2408.08578v2},
  langid = {english},
  file = {/Users/lixiuyin/Zotero/storage/4MQX6843/Zhu 等 - 2024 - TAMER Tree-aware transformer for handwritten mathematical expression recognition.pdf}
}

